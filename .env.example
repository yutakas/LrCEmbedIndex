# =============================================================================
# LrCEmbedIndex Docker Environment Configuration
#
# Copy this file to .env and adjust values for your deployment.
# Environment variables override saved JSON config on container restart.
# =============================================================================

# -- Docker volume mounts (host paths) ---------------------------------------
# INDEX_FOLDER: where index/metadata/chromadb data is stored on the host
# PHOTO_FOLDER: where your photo library lives on the host (mounted for patrol)
INDEX_FOLDER=/path/to/index
PHOTO_FOLDER=/path/to/photos

# -- Timezone -----------------------------------------------------------------
# Controls local time used by patrol time windows and log timestamps.
# Auto-detected by rebuild.sh; set explicitly here if needed.
# Examples: America/Los_Angeles, America/New_York, Asia/Tokyo, Europe/London
TZ=America/Los_Angeles

# -- Vision model -------------------------------------------------------------
# Supported modes: ollama, openai, claude
VISION_MODE=ollama
OLLAMA_VISION_ENDPOINT=http://host.docker.internal:11434
OLLAMA_VISION_MODEL=qwen3-vl:8b

# Uncomment for OpenAI vision:
# VISION_MODE=openai
# OPENAI_VISION_API_KEY=sk-...
# OPENAI_VISION_MODEL=gpt-4o

# Uncomment for Claude vision:
# VISION_MODE=claude
# CLAUDE_VISION_API_KEY=sk-ant-...
# CLAUDE_VISION_MODEL=claude-sonnet-4-20250514

# -- Embedding model ----------------------------------------------------------
# Supported modes: ollama, openai, voyage
EMBED_MODE=ollama
OLLAMA_EMBED_ENDPOINT=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:latest

# Uncomment for OpenAI embeddings:
# EMBED_MODE=openai
# OPENAI_EMBED_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Uncomment for Voyage embeddings:
# EMBED_MODE=voyage
# VOYAGE_EMBED_API_KEY=pa-...
# VOYAGE_EMBED_MODEL=voyage-3

# -- Search -------------------------------------------------------------------
# SEARCH_MAX_RESULTS=20
# SEARCH_RELEVANCE=50

# -- Thumbnails & Privacy -----------------------------------------------------
# THUMBNAIL_STORE_SIZE=512
# STRIP_GPS_FOR_CLOUD=true

# -- Debug --------------------------------------------------------------------
# Set to true to enable DEBUG-level logging (verbose, includes time window
# checks, env override details, etc.)
# DEBUG_LOGGING=false

# -- Patrol (auto-indexing) ---------------------------------------------------
# Enable automatic background scanning of PHOTO_FOLDER
PATROL_ENABLED=true
PATROL_INTERVAL_MINUTES=5
PATROL_BATCH_SIZE=10

# Time window (24h HH:MM format). Patrol only runs between start and end.
# Supports overnight windows (e.g. 22:00 to 06:00).
# Leave both empty for no restriction.
PATROL_START_TIME=12:00
PATROL_END_TIME=03:00
